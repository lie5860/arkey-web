{
  "name": "arkey-web",
  "version": "0.1.6",
  "private": true,
  "description": "Web control surface and ESP32-S3 bridge for a Codex Micro interoperability lab",
  "type": "module",
  "workspaces": [
    "apps/ArkeyWeb"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "web:build": "npm run build --workspace @arkey/web",
    "web:check": "npm run check --workspace @arkey/web",
    "app": "npm run desktop:dev --workspace @arkey/web",
    "app:build": "npm run desktop:build --workspace @arkey/web",
    "app:check": "npm run desktop:check --workspace @arkey/web",
    "web": "npm run build && npm run web:build && node dist/src/webserver.js",
    "firmware:test": "./scripts/test-codex-micro-esp32s3-protocol.sh",
    "firmware:build": "./scripts/build-codex-micro-esp32s3-lab.sh --acknowledge-device-identity-test",
    "lint": "tsc -p tsconfig.json --noEmit && npm run web:check",
    "test": "npm run build && npm run firmware:test && node --test dist/test/codex-micro-esp32s3-lab.test.js dist/test/microbridge.test.js dist/test/webserver.test.js",
    "check": "npm run lint && npm test && npm run web:build && npm run app:check"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lie5860/arkey-web.git"
  },
  "keywords": [
    "codex-micro",
    "esp32-s3",
    "webhid",
    "uart"
  ],
  "dependencies": {
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
