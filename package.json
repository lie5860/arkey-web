{
  "name": "arkey",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial, noncommercial Codex command surface with App Server and isolated Codex Micro laboratory modes",
  "type": "module",
  "workspaces": [
    "apps/ArkeyWeb"
  ],
  "bin": {
    "arkey": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "assets/arkey-logo.png",
    "apps/ArkeyMac/Package.swift",
    "apps/ArkeyMac/Package.resolved",
    "apps/ArkeyMac/Resources",
    "apps/ArkeyMac/Sources",
    "apps/ArkeyMac/Tests",
    "apps/CodexMicroVirtualLab/Package.swift",
    "apps/CodexMicroVirtualLab/CodexMicroVirtualLab.entitlements",
    "apps/CodexMicroVirtualLab/CodexMicroVirtualLab.xcodeproj",
    "apps/CodexMicroVirtualLab/Sources",
    "apps/CodexMicroVirtualLab/Tests",
    "apps/ArkeyWeb/dist",
    "apps/ArkeyWeb/package.json",
    "profiles",
    "firmware/UPSTREAM.md",
    "firmware/*.patch",
    "firmware/qmk",
    "firmware/esp32s3-codex-micro-lab/CMakeLists.txt",
    "firmware/esp32s3-codex-micro-lab/dependencies.lock",
    "firmware/esp32s3-codex-micro-lab/sdkconfig.defaults",
    "firmware/esp32s3-codex-micro-lab/main",
    "firmware/esp32s3-codex-micro-lab/test",
    "docs/ARCHITECTURE.md",
    "docs/CODEX_MICRO_LAB.md",
    "docs/CODEX_MICRO_ESP32S3_LAB.md",
    "docs/FIRMWARE.md",
    "docs/PORTING_QMK.md",
    "docs/WEB_CONSOLE.md",
    "scripts/audit-release.sh",
    "scripts/build-macos-app.sh",
    "scripts/build-q6-pro.sh",
    "scripts/build-codex-micro-lab-q6-pro.sh",
    "scripts/check-codex-app-server.sh",
    "scripts/check-command-surface.sh",
    "scripts/build-codex-micro-virtual-lab.sh",
    "scripts/build-codex-micro-esp32s3-lab.sh",
    "scripts/test-codex-micro-esp32s3-protocol.sh",
    "scripts/codex-micro-lab-bindings.mjs",
    "scripts/codex-micro-lab-config.mjs",
    "scripts/run-codex-micro-virtual-lab.command",
    "scripts/generate-firmware-contract.mjs",
    "test/codex-micro-lab.test.ts",
    "test/codex-micro-lab-bindings.test.ts",
    "test/codex-micro-esp32s3-lab.test.ts",
    "test/microbridge.test.ts",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "LICENSES",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "TRADEMARKS.md"
  ],
  "scripts": {
    "codex-micro-lab:status": "node scripts/codex-micro-lab-config.mjs status",
    "codex-micro-lab:configure": "node scripts/codex-micro-lab-config.mjs configure",
    "codex-micro-lab:sync": "node scripts/codex-micro-lab-config.mjs sync-arkey",
    "codex-micro-virtual-lab:test": "swift test --package-path apps/CodexMicroVirtualLab",
    "codex-micro-esp32s3-lab:test": "./scripts/test-codex-micro-esp32s3-protocol.sh",
    "codex-micro-esp32s3-lab:build": "./scripts/build-codex-micro-esp32s3-lab.sh --acknowledge-device-identity-test",
    "generate:firmware-contract": "node scripts/generate-firmware-contract.mjs",
    "check:firmware-contract": "node scripts/generate-firmware-contract.mjs --check",
    "audit:release": "./scripts/audit-release.sh",
    "build": "tsc -p tsconfig.json",
    "web:build": "npm run build --workspace @arkey/web",
    "web:check": "npm run check --workspace @arkey/web",
    "web": "npm run build && npm run web:build && node dist/src/webserver.js",
    "lint": "npm run check:firmware-contract && tsc -p tsconfig.json --noEmit && npm run web:check",
    "test": "npm run build && npm run codex-micro-esp32s3-lab:test && node --test dist/test/*.test.js",
    "check": "npm run audit:release && npm run lint && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lie5860/arkey-web.git"
  },
  "keywords": [
    "qmk",
    "rgb",
    "codex",
    "codex-micro",
    "keyboard",
    "raw-hid",
    "macos",
    "agentglow"
  ],
  "dependencies": {
    "node-hid": "^3.2.0",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
