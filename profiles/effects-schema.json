{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arkey Effect Catalog v1",
  "type": "object",
  "required": ["version", "atmosphereMix", "selectedPulsePeriodMs", "primitives", "semantics", "voice", "priority"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "atmosphereMix": { "type": "number", "minimum": 0, "maximum": 1 },
    "selectedPulsePeriodMs": { "type": "integer", "minimum": 250, "maximum": 10000 },
    "primitives": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 255 }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/semantic" }
    },
    "voice": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/voice" }
    },
    "priority": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "semantic": {
      "type": "object",
      "required": ["hex", "hue", "saturation", "value", "basePrimitive", "selectedPrimitive"],
      "properties": {
        "hex": { "type": "string", "pattern": "^#[A-F0-9]{6}$" },
        "hue": { "type": "integer", "minimum": 0, "maximum": 255 },
        "saturation": { "type": "integer", "minimum": 0, "maximum": 255 },
        "value": { "type": "integer", "minimum": 0, "maximum": 255 },
        "basePrimitive": { "type": "string" },
        "selectedPrimitive": { "type": "string" },
        "entryPrimitive": { "type": "string" },
        "entryDurationMs": { "type": "integer", "minimum": 0, "maximum": 655350 }
      },
      "additionalProperties": false
    },
    "voice": {
      "type": "object",
      "required": ["hex", "hue", "saturation", "value", "primitive"],
      "properties": {
        "hex": { "type": "string", "pattern": "^#[A-F0-9]{6}$" },
        "hue": { "type": "integer", "minimum": 0, "maximum": 255 },
        "saturation": { "type": "integer", "minimum": 0, "maximum": 255 },
        "value": { "type": "integer", "minimum": 0, "maximum": 255 },
        "primitive": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
