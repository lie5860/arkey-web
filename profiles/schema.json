{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shuhari04/arkey/blob/main/profiles/schema.json",
  "title": "Arkey KeyboardProfileV2",
  "type": "object",
  "required": [
    "profileId",
    "version",
    "layoutHash",
    "name",
    "transports",
    "matrix",
    "ledCount",
    "controls",
    "encoder",
    "characterMap",
    "randomKeys"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "profileId": { "type": "string", "minLength": 1 },
    "version": { "const": 2 },
    "layoutHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "name": { "type": "string", "minLength": 1 },
    "transports": {
      "type": "object",
      "required": ["usb", "bluetooth"],
      "properties": {
        "usb": { "$ref": "#/$defs/transport" },
        "bluetooth": { "$ref": "#/$defs/transport" }
      },
      "additionalProperties": false
    },
    "matrix": {
      "type": "object",
      "required": ["rows", "columns"],
      "properties": {
        "rows": { "type": "integer", "minimum": 1, "maximum": 16 },
        "columns": { "type": "integer", "minimum": 1, "maximum": 32 }
      },
      "additionalProperties": false
    },
    "ledCount": { "type": "integer", "minimum": 1, "maximum": 255 },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/keyControl" }
    },
    "encoder": { "$ref": "#/$defs/encoder" },
    "characterMap": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 254 }
    },
    "randomKeys": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 254 }
    }
  },
  "$defs": {
    "transport": {
      "type": "object",
      "required": ["vendorId", "productIds", "usagePage", "usage", "mode"],
      "properties": {
        "vendorId": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "productIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 65535 }
        },
        "usagePage": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "usage": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "mode": { "enum": ["full", "degraded"] }
      },
      "additionalProperties": false
    },
    "matrix": {
      "type": "object",
      "required": ["row", "column"],
      "properties": {
        "row": { "type": "integer", "minimum": 0 },
        "column": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "rect": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number", "minimum": 0 },
        "y": { "type": "number", "minimum": 0 },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "keyControl": {
      "type": "object",
      "required": ["id", "kind", "label", "code", "matrix", "ledIndex", "bindable", "unit", "frame"],
      "properties": {
        "id": { "type": "string", "pattern": "^r[0-9]+c[0-9]+$" },
        "kind": { "enum": ["key", "knobPress"] },
        "label": { "type": "string" },
        "code": { "type": "string" },
        "matrix": { "$ref": "#/$defs/matrix" },
        "ledIndex": { "type": ["integer", "null"], "minimum": 0, "maximum": 254 },
        "bindable": { "type": "boolean" },
        "unit": { "$ref": "#/$defs/rect" },
        "frame": { "$ref": "#/$defs/rect" }
      },
      "additionalProperties": false
    },
    "encoder": {
      "type": "object",
      "required": ["id", "kind", "label", "index", "pressControlId", "bindable", "ledIndex", "unit", "frame"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "encoder" },
        "label": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "pressControlId": { "type": "string" },
        "bindable": { "type": "boolean" },
        "ledIndex": { "type": "null" },
        "unit": { "$ref": "#/$defs/rect" },
        "frame": { "$ref": "#/$defs/rect" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
